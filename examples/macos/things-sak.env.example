# Copy this file to:
#   ~/Library/Application Support/things-sak/things-sak.env
# Then edit the values and keep permissions tight:
#   chmod 600 ~/Library/Application\ Support/things-sak/things-sak.env

# LAN address of the Mac running Things. Use 127.0.0.1 for local-only access.
THINGS_SAK_BIND=192.168.1.20

# Port for the streamable HTTP MCP server.
THINGS_SAK_PORT=32123

# Bearer token required by MCP clients. Generate one with:
#   openssl rand -base64 32
THINGS_SAK_TOKEN=change-me

# Optional but required for update/complete/move tools.
# Things → Settings → General → Enable Things URLs → Manage
THINGS_SAK_AUTH_TOKEN=

# Optional extra host accepted by the HTTP transport's Host-header validation,
# for example: my-mac.local:32123
THINGS_SAK_ALLOWED_HOST=
